#!/usr/bin/env bash
# Local pre-push hook: runs e2e tests on macOS before pushing.
# Enroll with: make hooks
# Bypass with: git push --no-verify
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "pre-push: running e2e tests..."
go build -o "$REPO_ROOT/dist/workbench-test" "$REPO_ROOT"
PATH="$REPO_ROOT/dist:$PATH" bash "$REPO_ROOT/scripts/e2e.sh"
rm -f "$REPO_ROOT/dist/workbench-test"
echo "pre-push: e2e passed"
