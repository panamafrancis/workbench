layout {
    tab name="workbench" focus=true {
        pane split_direction="vertical" {
            pane size="{{.SidebarWidth}}" name="sidebar" {
                command "bash"
                args "-c" "while true; do workbench ls && sleep 0.2 || sleep 2; done"
                env {
                    WORKBENCH_SIDEBAR "1"
                }
            }
            pane name="shell" focus=true
        }
    }
}
