layout {
    tab name="workbench" focus=true {
        pane split_direction="vertical" {
            pane size="15%" name="sidebar" {
                command "bash"
                args "-c" "WORKBENCH_SIDEBAR=1 exec bash -c 'while true; do workbench ls && sleep 0.2 || sleep 2; done'"
            }
            pane name="shell" focus=true
        }
    }
}
